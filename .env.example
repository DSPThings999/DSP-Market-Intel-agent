# --- Data APIs (all free tier) ---
FINNHUB_API_KEY=your_finnhub_api_key

# --- AI classifier ---
# "gemini" is active by default: genuinely free forever, no card, no expiration.
# "grok" is also wired up (promo credits only, not permanently free).
# "claude" is commented out in classifier.py until you're ready to switch.
CLASSIFIER_PROVIDER=gemini
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# Only needed if you set CLASSIFIER_PROVIDER=grok
GROK_API_KEY=your_xai_api_key
GROK_MODEL=grok-4.3

# Only needed once you switch CLASSIFIER_PROVIDER back to "claude"
ANTHROPIC_API_KEY=your_anthropic_api_key
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# --- Alerting (free) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Local testing only (GitHub Actions handles scheduling in production) ---
POLL_INTERVAL_MINUTES=15

# --- Optional upgrade path, not required for the $0/month stack ---
# POLYGON_API_KEY=your_polygon_api_key
